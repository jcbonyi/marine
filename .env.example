# Set this to your backend endpoint that receives POST submissions
# and forwards email to ADT operations (see submit.ts for payload format).
# Leave unset for local dev — submissions log to console and show confirmation.
#
# JSON only (no files):
#   Content-Type: application/json
#
# With uploaded documents:
#   Content-Type: multipart/form-data
#   - payload: JSON string (submission metadata)
#   - proformaInvoice, idf, billOfLading, packingList: file fields
VITE_SUBMIT_URL=

# Frontend submit endpoint. In production this defaults to /api/submit on the same domain.
# Leave unset for local Vite dev unless you run `vercel dev`.
# VITE_SUBMIT_URL=

# SMTP settings for /api/submit (required in production to email submissions)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@adtinsurance.co.ke
